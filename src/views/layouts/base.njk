<!DOCTYPE html>

<html lang="en">

    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>{% if title %}{{ title }} | Michelle Enos{% else %}Michelle Enos{% endif %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

        <link rel="stylesheet" type="text/css" href="{{ '/styles/style.css' | url }}"/>
		<link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />

		<meta name="author" content="Michelle Enos">
	    {% if excerpt %}<meta name="description" content="{{ excerpt | escape }}">{% endif %}

	    {# Open Graph #}
	    <meta property="og:site_name" content="Michelle Enos">
	    <meta property="og:title" content="{% if title %}{{ title | escape }}{% else %}Michelle Enos{% endif %}">
	    {% if excerpt %}<meta property="og:description" content="{{ excerpt | escape }}">{% endif %}
	    <meta property="og:type" content="{% if date %}article{% else %}website{% endif %}">
		<meta property="og:url" content="{{ site.url }}{{ page.url }}">

		{% if img %}
			<meta property="og:image" content="{{ site.url }}{{ img }}">
			<meta name="twitter:image" content="{{ site.url }}{{ img }}">
			<meta name="twitter:card" content="summary_large_image">
		{% elif image %}
			<meta property="og:image" content="{{ site.url }}{{ image }}">
			<meta name="twitter:image" content="{{ site.url }}{{ image }}">
			<meta name="twitter:card" content="summary_large_image">
		{% else %}
			<meta name="twitter:card" content="summary">
		{% endif %}


		{% if date %}<meta property="article:published_time" content="{{ date | dateIso }}">{% endif %}
		{% if dateUpdated %}<meta property="article:modified_time" content="{{ dateUpdated | dateIso }}">{% endif %}

		{# twitter/x card #}
    	<meta name="twitter:title" content="{% if title %}{{ title | escape }}{% else %}Michelle Enos{% endif %}">
		{% if excerpt %}<meta name="twitter:description" content="{{ excerpt | escape }}">{% endif %}


    </head>

    <body class="page-{{title | slugify}}">
        <a class="sr-text" href="#main">skip to content</a>

        <div class='page-wrap'>
            <header class='header'>
                {% include 'partials/nav.njk' %}
            </header>

            {% block baseContent %}
                {{ content | safe }}
            {% endblock %}

            {% include 'partials/footer.njk' %}
        </div>

        {% for script in footerScripts %}
            <script src={{ script | url }}></script>
        {% endfor %}
        {# <script src="/scripts/nav.js"></script> #}

    </body>

</html>